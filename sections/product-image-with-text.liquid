{%- if section.settings.image != blank or section.blocks.size > 0 -%}
  <style>
    #shopify-section-{{ section.id }} {
      --image-with-text-content-max-width: {% if section.settings.content_width == 'sm' %}430px{% elsif section.settings.content_width == 'md' %}780px{% else %}100%{% endif %};
    }
    #shopify-section-{{ section.id }} .image-with-text {
      --image-with-text-gap: {{ section.settings.image_text_gap }}px;
      overflow: visible;
    }
    #shopify-section-{{ section.id }} .product-iwt-image {
      padding-top: {{ section.settings.image_padding_top }}px;
      padding-right: {{ section.settings.image_padding_right }}px;
      padding-bottom: {{ section.settings.image_padding_bottom }}px;
      padding-left: {{ section.settings.image_padding_left }}px;
    }
    #shopify-section-{{ section.id }} .product-iwt-image > :is(svg, img) {
      width: 100%;
      max-height: {{ section.settings.image_max_height }}px;
      object-fit: cover;
      display: block;
      border-radius: {{ section.settings.image_border_radius }}px;
      {%- if section.settings.image_shadow != 'none' -%}
        box-shadow: {{ section.settings.image_shadow }};
      {%- endif -%}
    }
    #shopify-section-{{ section.id }} .image-with-text--reverse > .product-iwt-image {
      order: 9999;
    }
    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }} .image-with-text--reverse > .product-iwt-image {
        order: -1;
      }
      {%- if section.settings.mobile_image_fit == 'contain' -%}
        #shopify-section-{{ section.id }} .product-iwt-image > :is(svg, img) {
          object-fit: contain;
          max-height: {{ section.settings.mobile_image_max_height }}px;
        }
      {%- endif -%}
      {%- if section.settings.mobile_collapse_text -%}
        #shopify-section-{{ section.id }} .product-iwt-richtext {
          display: -webkit-box;
          -webkit-line-clamp: {{ section.settings.mobile_text_lines }};
          -webkit-box-orient: vertical;
          overflow: hidden;
        }
        #shopify-section-{{ section.id }} .product-iwt-richtext.is-expanded {
          display: block;
          -webkit-line-clamp: unset;
          overflow: visible;
        }
        #shopify-section-{{ section.id }} .product-iwt-read-more {
          display: inline-block;
          margin-top: 0.5rem;
          font-size: 0.875rem;
          font-weight: 600;
          cursor: pointer;
          text-decoration: underline;
          text-underline-offset: 3px;
        }
      {%- else -%}
        #shopify-section-{{ section.id }} .product-iwt-read-more {
          display: none;
        }
      {%- endif -%}
    }
    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} .product-iwt-read-more {
        display: none;
      }
      #shopify-section-{{ section.id }} .image-with-text {
        grid-template-columns: {{ section.settings.image_width }}fr {{ 100 | minus: section.settings.image_width }}fr;
        align-items: {{ section.settings.text_position }};
      }
      #shopify-section-{{ section.id }} .image-with-text--reverse {
        grid-template-columns: {{ 100 | minus: section.settings.image_width }}fr {{ section.settings.image_width }}fr;
      }
    }
  </style>

  {%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

  <div class="{% unless section.settings.remove_vertical_spacing %}section-spacing{% endunless %} color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
    <image-with-text class="image-with-text {% if section.settings.image_position == 'end' %}image-with-text--reverse{% endif %}">
      <div class="product-iwt-image">
        {%- if section.settings.image != blank -%}
          {%- assign sizes = '(max-width: 699px) 100vw, 50vw' -%}
          {{- section.settings.image | image_url: width: section.settings.image.width | image_tag: sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200', reveal-on-scroll: section.settings.reveal_on_scroll -}}
        {%- elsif section.settings.image_fallback != 'none' and product != blank -%}
          {%- assign fi = section.settings.image_fallback | plus: 0 -%}
          {%- assign fallback_img = product.images[fi] -%}
          {%- if fallback_img != blank -%}
            {%- assign sizes = '(max-width: 699px) 100vw, 50vw' -%}
            {{- fallback_img | image_url: width: fallback_img.width | image_tag: sizes: sizes, widths: '200,300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200', loading: 'lazy' -}}
          {%- else -%}
            {{- 'image' | placeholder_svg_tag: 'placeholder' -}}
          {%- endif -%}
        {%- else -%}
          {{- 'image' | placeholder_svg_tag: 'placeholder' -}}
        {%- endif -%}
      </div>

      <div class="prose text-center sm:text-{{ section.settings.text_alignment }}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'subheading' -%}
              {%- if block.settings.text != blank -%}
                <p class="h6" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- endif -%}

            {%- when 'heading' -%}
              {%- if block.settings.text != blank -%}
                <p class="{{ block.settings.heading_tag }}" style="font-size: {{ block.settings.font_size }}px;" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- endif -%}

            {%- when 'richtext' -%}
              {%- if block.settings.content != blank -%}
                <div class="product-iwt-richtext" style="font-size: {{ block.settings.font_size }}px;" {{ block.shopify_attributes }}>
                  {{- block.settings.content -}}
                </div>
                <button type="button" class="product-iwt-read-more" onclick="this.previousElementSibling.classList.toggle('is-expanded');this.textContent=this.previousElementSibling.classList.contains('is-expanded')?'Read less':'Read more'">Read more</button>
              {%- endif -%}

            {%- when 'button' -%}
              {%- if block.settings.text != blank -%}
                {% render 'button', content: block.settings.text, href: block.settings.url, style: block.settings.style, background: block.settings.background, text_color: block.settings.text_color, block: block %}
              {%- endif -%}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </image-with-text>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product image with text",
  "class": "shopify-section--product-image-with-text",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "t:global.section.separate_section_with_border",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:global.image.image"
    },
    {
      "type": "checkbox",
      "id": "reveal_on_scroll",
      "label": "t:global.animation.reveal_image_on_scroll",
      "default": true
    },
    {
      "type": "select",
      "id": "image_fallback",
      "label": "Fallback to product image",
      "info": "If no image is selected above, use this product image instead. Only works on product pages.",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "0", "label": "1st product image" },
        { "value": "1", "label": "2nd product image" },
        { "value": "2", "label": "3rd product image" },
        { "value": "3", "label": "4th product image" },
        { "value": "4", "label": "5th product image" }
      ]
    },
    {
      "type": "range",
      "id": "image_max_height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Image max height",
      "info": "Limits how tall the image can be. Set to 800 for no limit.",
      "default": 800
    },
    {
      "type": "header",
      "content": "Image padding"
    },
    {
      "type": "range",
      "id": "image_padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_padding_right",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding right",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_padding_left",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding left",
      "default": 0
    },
    {
      "type": "header",
      "content": "Image effects"
    },
    {
      "type": "select",
      "id": "image_shadow",
      "label": "Image shadow",
      "info": "Adds a shadow around the image to make it pop.",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "0 0 8px 2px rgba(0,0,0,0.08)", "label": "Subtle" },
        { "value": "0 0 16px 4px rgba(0,0,0,0.12)", "label": "Medium" },
        { "value": "0 0 24px 6px rgba(0,0,0,0.16)", "label": "Strong" },
        { "value": "0 0 32px 8px rgba(0,0,0,0.22)", "label": "Extra strong" }
      ]
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "info": "Rounds the corners of the image.",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Image width (desktop)",
      "info": "Percentage of section width the image takes. Text fills the rest.",
      "default": 50
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "start",
          "label": "t:global.position.left"
        },
        {
          "value": "end",
          "label": "t:global.position.right"
        }
      ],
      "default": "start"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Right" }
      ],
      "default": "start"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text vertical position",
      "options": [
        { "value": "start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "image_text_gap",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Gap between image and text",
      "default": 48
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        {
          "value": "sm",
          "label": "t:global.sizes.small"
        },
        {
          "value": "md",
          "label": "t:global.sizes.medium"
        },
        {
          "value": "lg",
          "label": "t:global.sizes.large"
        }
      ],
      "default": "sm"
    },
    {
      "type": "header",
      "content": "Mobile settings"
    },
    {
      "type": "select",
      "id": "mobile_image_fit",
      "label": "Mobile image fit",
      "info": "Cover fills the space and may crop. Center shows the full image without cropping.",
      "options": [
        { "value": "cover", "label": "Cover (fill & crop)" },
        { "value": "contain", "label": "Center (full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "mobile_image_max_height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Mobile image max height",
      "info": "Only applies when mobile image fit is set to Center.",
      "default": 400
    },
    {
      "type": "checkbox",
      "id": "mobile_collapse_text",
      "label": "Collapse text on mobile",
      "info": "Shows a 'Read more' button on mobile when text is long.",
      "default": false
    },
    {
      "type": "range",
      "id": "mobile_text_lines",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Visible lines before collapse",
      "info": "Number of text lines shown before 'Read more' on mobile.",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "remove_vertical_spacing",
      "label": "t:global.spacing.remove_vertical_spacing",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "t:global.text.text",
          "default": "Subheading"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "t:global.text.text",
          "default": "Heading"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "t:global.text.style",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "h4", "label": "H4" },
            { "value": "h5", "label": "H5" },
            { "value": "h6", "label": "H6" }
          ],
          "default": "h2"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 12,
          "max": 72,
          "step": 2,
          "unit": "px",
          "label": "Font size",
          "default": 32
        }
      ]
    },
    {
      "type": "richtext",
      "name": "Paragraph",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "t:global.text.content",
          "default": "<p>Use this text to share information about your product.</p>"
        },
        {
          "type": "range",
          "id": "font_size",
          "min": 10,
          "max": 32,
          "step": 1,
          "unit": "px",
          "label": "Font size",
          "default": 16
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "t:global.text.style",
          "options": [
            { "value": "outline", "label": "Outline" },
            { "value": "solid", "label": "Solid" }
          ],
          "default": "solid"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:global.text.text",
          "default": "Button text"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "background",
          "label": "t:global.colors.background"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product image with text",
      "category": "t:global.categories.media",
      "blocks": [
        { "type": "subheading", "settings": { "text": "Subheading" } },
        { "type": "heading", "settings": { "text": "Product feature" } },
        { "type": "richtext" }
      ]
    }
  ]
}
{% endschema %}
