{%- if section.blocks.size > 0 -%}
  {%- assign color_scheme_hash = section.settings.color_scheme.settings.background_gradient | default: section.settings.color_scheme.settings.background | md5 -%}

  <div class="section-spacing color-scheme color-scheme--{{ section.settings.color_scheme.id }} color-scheme--bg-{{ color_scheme_hash }} {% if section.settings.separate_section_with_border %}bordered-section{% endif %}">
    <div class="container container--md">
      <div class="section-stack">
        {%- render 'section-header', subheading: section.settings.subheading, heading: section.settings.title -%}

        <div class="faq__content">
          {%- for block in section.blocks -%}
            {%- if block.settings.question != blank and block.settings.answer != blank -%}
              {%- capture answer -%}
                <div class="prose">
                  {{- block.settings.answer -}}
                </div>
              {%- endcapture -%}

              {%- assign open_first = false -%}
              {%- if section.settings.open_first_row and forloop.first -%}
                {%- assign open_first = true -%}
              {%- endif -%}

              {%- render 'accordion', title: block.settings.question, content: answer, show_title_as_text: true, open: open_first, block: block -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- assign has_output = false -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank and block.settings.answer != blank -%}
            {%- if has_output -%},{%- endif -%}
            {
              "@type": "Question",
              "name": {{ block.settings.question | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ block.settings.answer | strip_html | json }}
              }
            }
            {%- assign has_output = true -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Product FAQ",
  "class": "shopify-section--product-faq",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.colors.scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "separate_section_with_border",
      "label": "t:global.section.separate_section_with_border",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Got questions?"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "checkbox",
      "id": "open_first_row",
      "label": "Open first question by default",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "question",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Write a clear and concise answer to guide your customers.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product FAQ",
      "category": "t:global.categories.trust_social",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What is the shipping time?",
            "answer": "<p>Standard shipping takes 7-15 business days depending on your location.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return policy on all items.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How can I track my order?",
            "answer": "<p>You'll receive a tracking number via email once your order ships.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Yes, we ship worldwide. Shipping costs vary by destination.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
