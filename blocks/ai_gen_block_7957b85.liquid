{% doc %}
  @prompt
    create a icon section
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-icon-section__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-icon-section__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-icon-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-icon-section__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.text_alignment }};
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-icon-section__icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
  }

  .ai-icon-section__icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.6);
    height: calc({{ block.settings.icon_size }}px * 0.6);
    object-fit: contain;
  }

  .ai-icon-section__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-icon-section__content-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-icon-section__title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-icon-section__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-icon-section__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<icon-section-{{ ai_gen_id }}
  class="ai-icon-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-icon-section__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-icon-section__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-icon-section__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign title_key = 'title_' | append: i
          assign text_key = 'text_' | append: i

          assign icon = block.settings[icon_key]
          assign title = block.settings[title_key]
          assign text = block.settings[text_key]
        %}

        {% if icon != blank or title != blank or text != blank %}
          <div class="ai-icon-section__item-{{ ai_gen_id }}">
            {% if icon != blank %}
              <div class="ai-icon-section__icon-wrapper-{{ ai_gen_id }}">
                <div class="ai-icon-section__icon-{{ ai_gen_id }}">
                  <img
                    src="{{ icon | image_url: width: 200 }}"
                    alt="{{ title | escape }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                </div>
              </div>
            {% endif %}

            <div class="ai-icon-section__content-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3 class="ai-icon-section__title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}

              {% if text != blank %}
                <div class="ai-icon-section__text-{{ ai_gen_id }}">{{ text }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</icon-section-{{ ai_gen_id }}>

<script>
  (function() {
    class IconSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('icon-section-{{ ai_gen_id }}', IconSection{{ ai_gen_id }});
  })();
</script>

