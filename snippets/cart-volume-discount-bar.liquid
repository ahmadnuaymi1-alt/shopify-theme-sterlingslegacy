{%- comment -%}
  Volume Discount Progress Bar for Prestige theme.
  Tracks highest same-product quantity in cart.
  Settings from cart-drawer section.
{%- endcomment -%}

{%- liquid
  assign max_same_qty = 0

  for item in cart.items
    assign product_qty = 0
    for check_item in cart.items
      if check_item.product.id == item.product.id
        assign product_qty = product_qty | plus: check_item.quantity
      endif
    endfor
    if product_qty > max_same_qty
      assign max_same_qty = product_qty
    endif
  endfor

  assign tier_1_qty = section.settings.vd_tier_1_qty
  assign tier_1_pct = section.settings.vd_tier_1_percent
  assign tier_2_enabled = section.settings.vd_tier_2_enabled
  assign tier_2_qty = section.settings.vd_tier_2_qty
  assign tier_2_pct = section.settings.vd_tier_2_percent

  if tier_2_enabled
    assign highest_goal = tier_2_qty | times: 1.0
  else
    assign highest_goal = tier_1_qty | times: 1.0
  endif

  assign bar_pct = max_same_qty | divided_by: highest_goal | times: 100.0
  if bar_pct > 100.0
    assign bar_pct = 100
  endif

  assign tier_1_pos = tier_1_qty | divided_by: highest_goal | times: 100.0

  assign tier_1_reached = false
  assign all_reached = false

  if max_same_qty >= tier_1_qty
    assign tier_1_reached = true
  endif

  if tier_2_enabled and max_same_qty >= tier_2_qty
    assign all_reached = true
  elsif tier_2_enabled == false and max_same_qty >= tier_1_qty
    assign all_reached = true
  endif

  assign amount_needed = 0
  assign current_label = ''
  assign next_label = ''

  if all_reached == false and tier_1_reached == false
    assign amount_needed = tier_1_qty | minus: max_same_qty
    assign next_label = tier_1_pct | append: '% off'
  elsif all_reached == false and tier_1_reached
    assign amount_needed = tier_2_qty | minus: max_same_qty
    assign current_label = tier_1_pct | append: '% off'
    assign next_label = tier_2_pct | append: '% off'
  endif

  assign vd_color = section.settings.vd_bar_color | default: '#0D8756'
-%}

{%- if cart != empty -%}
  <style>
    .vd{--c:{{ vd_color }};padding:12px 20px 36px;text-align:center}
    .vd__msg{font-size:13px;font-weight:600;line-height:1.4;margin:0 0 16px;color:rgb(var(--text-color,0,0,0))}
    .vd__msg strong{font-weight:700;color:var(--c)}
    .vd__track{position:relative;height:10px;border-radius:99px;background:rgba(var(--text-color,0,0,0),.10);margin:0 28px}
    .vd__fill{position:absolute;top:0;left:0;height:100%;border-radius:99px;background:var(--c);transition:width .4s ease-out;display:block !important}
    .vd__node{position:absolute;top:50%;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;z-index:2}
    .vd__dot{width:32px;height:32px;border-radius:50%;background:#fff;border:2.5px solid rgba(0,0,0,.2);display:flex;align-items:center;justify-content:center;transition:all .3s ease}
    .vd__dot--on{background:var(--c);border-color:var(--c);box-shadow:0 0 0 4px rgba(0,0,0,.06)}
    .vd__dot svg{width:14px;height:14px;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
    .vd__dot--off svg{stroke:rgba(0,0,0,.35)}
    .vd__dot--on svg{stroke:#fff}
    .vd__lbl{position:absolute;top:calc(100% + 7px);font-size:11px;line-height:1.3;font-weight:600;white-space:nowrap;color:rgba(0,0,0,.4);transition:color .3s}
    .vd__lbl--on{color:var(--c)}
    .vd__lbl small{display:block;font-size:10px;font-weight:500;opacity:.8}
  </style>

  <div class="vd">
    <p class="vd__msg">
      {%- if all_reached -%}
        {{ section.settings.vd_success_message }}
      {%- elsif tier_1_reached -%}
        {{ section.settings.vd_partial_message | replace: '[amount]', amount_needed | replace: '[current_tier]', current_label | replace: '[next_tier]', next_label }}
      {%- else -%}
        {{ section.settings.vd_progress_message | replace: '[amount]', amount_needed | replace: '[next_tier]', next_label }}
      {%- endif -%}
    </p>

    <div class="vd__track">
      <div class="vd__fill" style="width:{{ bar_pct }}%"></div>

      <div class="vd__node" style="left:{{ tier_1_pos }}%">
        <span class="vd__dot{% if tier_1_reached %} vd__dot--on{% else %} vd__dot--off{% endif %}">
          {%- if tier_1_reached -%}
            <svg viewBox="0 0 16 16"><polyline points="3.5 8.5 6.5 11.5 12.5 4.5"/></svg>
          {%- else -%}
            <svg viewBox="0 0 16 16"><path d="M9.5 2.5L13.5 6.5L6.5 13.5H2.5V9.5Z"/><line x1="10" y1="6" x2="14" y2="2"/></svg>
          {%- endif -%}
        </span>
        <span class="vd__lbl{% if tier_1_reached %} vd__lbl--on{% endif %}"><small>Buy {{ tier_1_qty }}</small>{{ tier_1_pct }}% off</span>
      </div>

      {%- if tier_2_enabled -%}
        <div class="vd__node" style="left:100%">
          <span class="vd__dot{% if all_reached %} vd__dot--on{% else %} vd__dot--off{% endif %}">
            {%- if all_reached -%}
              <svg viewBox="0 0 16 16"><polyline points="3.5 8.5 6.5 11.5 12.5 4.5"/></svg>
            {%- else -%}
              <svg viewBox="0 0 16 16"><path d="M9.5 2.5L13.5 6.5L6.5 13.5H2.5V9.5Z"/><line x1="10" y1="6" x2="14" y2="2"/></svg>
            {%- endif -%}
          </span>
          <span class="vd__lbl{% if all_reached %} vd__lbl--on{% endif %}"><small>Buy {{ tier_2_qty }}+</small>{{ tier_2_pct }}% off</span>
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}
