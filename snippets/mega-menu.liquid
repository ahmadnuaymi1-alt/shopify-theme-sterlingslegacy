{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
MEGA MENU COMPONENT - COLLECTION IMAGE GRID + FEATURED PRODUCTS
----------------------------------------------------------------------------------------------------------------------

Renders a visual grid of collection images with an optional featured products sidebar.
All layout settings (columns, image ratio, featured width) are configurable from the theme editor.

********************************************
Supported variables
********************************************

* link: the link from which we need to render the mega-menu
* block: the block containing all the information about the menu to render
{%- endcomment -%}

<style>
  .mega-menu__layout {
    display: flex;
    width: 100%;
    padding: 1.5rem 2rem;
  }

  .mega-menu__layout--reverse {
    flex-direction: row-reverse;
  }

  .mega-menu__collections {
    flex: 1;
    min-width: 0;
  }

  .mega-menu__collection-grid {
    display: grid;
    grid-template-columns: repeat(var(--collection-columns, 4), 1fr);
    gap: 1.25rem;
  }

  .mega-menu__collection-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
  }

  .mega-menu__collection-img {
    width: 100%;
    aspect-ratio: var(--image-ratio, 1);
    border-radius: 8px;
    overflow: hidden;
  }

  .mega-menu__collection-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .mega-menu__collection-card:hover .mega-menu__collection-img img {
    transform: scale(1.05);
  }

  .mega-menu__collection-name {
    font-size: 13px;
    line-height: 1.3;
    margin: 0;
  }

  .mega-menu__divider {
    width: 1px;
    background: rgba(0, 0, 0, 0.08);
    margin: 0 1.5rem;
    flex-shrink: 0;
  }

  .mega-menu__featured {
    width: var(--featured-width, 30%);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mega-menu__featured-heading {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    margin: 0 0 0.25rem;
  }

  .mega-menu__featured-product {
    display: flex;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }

  .mega-menu__featured-product-img {
    width: 70px;
    height: 70px;
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .mega-menu__featured-product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .mega-menu__featured-product:hover .mega-menu__featured-product-img img {
    transform: scale(1.05);
  }

  .mega-menu__featured-product-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.15rem;
  }

  .mega-menu__featured-product-title {
    font-size: 13px;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mega-menu__featured-product-price {
    font-size: 12px;
    opacity: 0.6;
    margin: 0;
  }
</style>

{%- comment -%}Check if any featured products are set{%- endcomment -%}
{%- assign has_featured = false -%}
{%- for i in (1..3) -%}
  {%- assign fp_key = 'featured_product_' | append: i -%}
  {%- if block.settings[fp_key] != blank -%}
    {%- assign has_featured = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%}Image ratio mapping{%- endcomment -%}
{%- case block.settings.image_ratio -%}
  {%- when 'portrait' -%}
    {%- assign ratio_value = '3/4' -%}
  {%- when 'landscape' -%}
    {%- assign ratio_value = '4/3' -%}
  {%- when 'auto' -%}
    {%- assign ratio_value = 'auto' -%}
  {%- else -%}
    {%- assign ratio_value = '1' -%}
{%- endcase -%}

<div class="mega-menu" {{ block.shopify_attributes }}>
  {%- if link.levels > 0 -%}
    <div class="mega-menu__layout {% if has_featured and block.settings.images_position == 'left' %}mega-menu__layout--reverse{% endif %}"
         style="--featured-width: {{ block.settings.featured_width | default: 30 }}%; --collection-columns: {{ block.settings.collection_columns | default: 4 }}; --image-ratio: {{ ratio_value }};">

      <div class="mega-menu__collections">
        <div class="mega-menu__collection-grid">
          {%- for sub_link in link.links -%}
            {%- assign col_handle = sub_link.url | split: '/collections/' | last | split: '?' | first | split: '/' | first -%}
            {%- assign col = collections[col_handle] -%}

            <a href="{{ sub_link.url }}" class="mega-menu__collection-card group">
              {%- if col.image -%}
                <div class="mega-menu__collection-img overflow-hidden">
                  {{- col.image | image_url: width: col.image.width | image_tag: loading: 'lazy', sizes: '180px', widths: '180,360,540', class: 'zoom-image' -}}
                </div>
              {%- elsif col != blank and col.products.first.featured_image -%}
                <div class="mega-menu__collection-img overflow-hidden">
                  {{- col.products.first.featured_image | image_url: width: col.products.first.featured_image.width | image_tag: loading: 'lazy', sizes: '180px', widths: '180,360,540', class: 'zoom-image' -}}
                </div>
              {%- else -%}
                <div class="mega-menu__collection-img" style="background: #f0f0f0;"></div>
              {%- endif -%}
              <p class="mega-menu__collection-name h6">{{ sub_link.title }}</p>
            </a>
          {%- endfor -%}
        </div>
      </div>

      {%- if has_featured -%}
        <div class="mega-menu__divider"></div>
        <div class="mega-menu__featured">
          <p class="mega-menu__featured-heading">Featured</p>
          {%- for i in (1..3) -%}
            {%- assign fp_key = 'featured_product_' | append: i -%}
            {%- assign featured_product = block.settings[fp_key] -%}
            {%- if featured_product != blank -%}
              <a href="{{ featured_product.url }}" class="mega-menu__featured-product group">
                {%- if featured_product.featured_image -%}
                  <div class="mega-menu__featured-product-img overflow-hidden">
                    {{- featured_product.featured_image | image_url: width: featured_product.featured_image.width | image_tag: loading: 'lazy', sizes: '70px', widths: '70,140,210', class: 'zoom-image' -}}
                  </div>
                {%- endif -%}
                <div class="mega-menu__featured-product-info">
                  <p class="mega-menu__featured-product-title h6">{{ featured_product.title }}</p>
                  <p class="mega-menu__featured-product-price">{{ featured_product.price | money }}</p>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
