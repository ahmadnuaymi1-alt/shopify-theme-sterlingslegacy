{%- comment -%}
  Payment Icons Block — shows enabled payment types under Add to Cart.
  Called with: {% render 'payment-icons-block', block: block %}
{%- endcomment -%}

{%- if shop.enabled_payment_types.size > 0 -%}
  <div class="payment-icons-block" {{ block.shopify_attributes }}>
    <ul class="payment-icons-block__list" role="list">
      {%- for type in shop.enabled_payment_types -%}
        <li>{{ type | payment_type_svg_tag: class: 'payment-icons-block__icon' }}</li>
      {%- endfor -%}
    </ul>
  </div>

  <style>
    .payment-icons-block {
      padding: 0;
    }
    /* Tighten gap between payment icons and adjacent blocks */
    [data-block-type="payment-icons"] {
      margin-block: -0.25rem;
    }
    .payment-icons-block__list {
      display: flex;
      flex-wrap: nowrap;
      justify-content: center;
      gap: 0.25rem;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .payment-icons-block__icon {
      height: 22px;
      width: auto;
      opacity: 0.9;
    }
    @media (max-width: 480px) {
      .payment-icons-block__icon {
        height: 18px;
      }
      .payment-icons-block__list {
        gap: 0.125rem;
      }
    }
  </style>
{%- endif -%}
